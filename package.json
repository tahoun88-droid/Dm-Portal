*{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,Tahoma,sans-serif;background:#f8fafc;color:#0f172a}button,input,select,textarea{font:inherit}button{border:0;background:#0f172a;color:#fff;border-radius:12px;padding:12px 16px;cursor:pointer;font-weight:700;display:inline-flex;gap:8px;align-items:center;justify-content:center}button:hover{opacity:.92}.outline{background:white;color:#0f172a;border:1px solid #cbd5e1}.secondary{background:#e2e8f0;color:#0f172a}input,select,textarea{width:100%;border:1px solid #cbd5e1;border-radius:12px;padding:12px;background:white}textarea{resize:vertical}.login-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}.login-card{width:100%;max-width:430px;background:white;border-radius:24px;box-shadow:0 20px 60px #0f172a20;padding:28px;text-align:center}.login-card input{margin-top:12px}.login-card button{width:100%;margin-top:12px}.logo{height:56px;width:56px;background:#0f172a;color:white;border-radius:18px;margin:0 auto 12px;display:flex;align-items:center;justify-content:center}.demo{margin-top:16px;background:#f1f5f9;border-radius:14px;padding:12px;color:#475569;text-align:left;font-size:13px}.app{max-width:1200px;margin:auto;padding:28px}header{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:22px}h1,h2,p{margin-top:0}header p,.card-head p,.small{color:#64748b}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}.stat{background:white;border-radius:20px;padding:18px;display:flex;gap:12px;align-items:center;box-shadow:0 8px 28px #0f172a0d}.stat-icon{height:42px;width:42px;background:#0f172a;color:white;border-radius:14px;display:flex;align-items:center;justify-content:center}.stat p{font-size:13px;color:#64748b;margin:0}.stat b{font-size:28px}nav{background:#e2e8f0;padding:5px;border-radius:14px;display:flex;gap:6px;width:max-content;margin-bottom:18px}nav button{background:transparent;color:#334155}nav button.active{background:white;color:#0f172a;box-shadow:0 2px 10px #0f172a12}.card{background:white;border-radius:22px;box-shadow:0 8px 28px #0f172a0d;padding:20px;margin-bottom:16px}.card-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.badge{display:inline-block;background:#0f172a;color:white;border-radius:999px;padding:6px 10px;font-size:12px;margin:0 0 10px 8px}.badge.light{background:#f1f5f9;color:#334155}.desc{color:#334155}.note{border-radius:14px;padding:12px;margin:10px 0}.amber{background:#fffbeb}.green{background:#ecfdf5}.history{background:#f1f5f9;color:#475569;border-radius:14px;padding:12px;font-size:13px}.action{border:1px solid #e2e8f0;border-radius:18px;padding:14px;margin-top:14px}.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}.empty{background:white;border-radius:22px;padding:45px;text-align:center;color:#64748b;box-shadow:0 8px 28px #0f172a0d}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:12px}.card textarea{margin:12px 0}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse}th,td{text-align:right;border-bottom:1px solid #e2e8f0;padding:12px;white-space:nowrap}.small{font-size:12px;margin-top:12px}@media(max-width:800px){.app{padding:16px}header{align-items:flex-start;flex-direction:column}.stats{grid-template-columns:repeat(2,1fr)}nav{width:100%;overflow:auto}nav button{white-space:nowrap}.grid{grid-template-columns:1fr}.card-head{flex-direction:column}.actions button{width:100%}}@media(max-width:420px){.stats{grid-template-columns:1fr}.stat b{font-size:22px}}
